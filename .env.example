# ====================================================================
# Cognitive Search Engine — Environment Variables Template
# ====================================================================
# 复制此文件为 .env 并填入你的密钥：
#   cp .env.example .env
#
# ⚠️ 安全警告：
#   - .env 已加入 .gitignore，永远不要删除它
#   - 不要将 .env 提交到 GitHub 或任何公开仓库
#   - 密钥泄露后立即轮换
# ====================================================================

# ─── Tavily AI Search ───────────────────────────────────────────
# 获取: https://app.tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# ─── Exa (formerly Metaphor) Semantic Search ────────────────────
# 获取: https://exa.ai/
EXA_API_KEY=your_exa_api_key_here

# ─── DeepSeek API (LLM 推理) ────────────────────────────────────
# 获取: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ─── Optional: GitHub Token (用于 ghcr.io 拉取 MCP 镜像) ──────
GITHUB_TOKEN=your_github_token_here
